{
	"$schema": "https://schemas.wp.org/trunk/theme.json",
	"version": 2,
	"settings": {
		"appearanceTools": true,
		"layout": {
			"contentSize": "760px",
			"wideSize": "1180px"
		},
		"color": {
			"palette": [
				{ "slug": "primary", "color": "#2563eb", "name": "Primary" },
				{ "slug": "dark", "color": "#0f172a", "name": "Dark" },
				{ "slug": "light", "color": "#f8fafc", "name": "Light" },
				{ "slug": "white", "color": "#ffffff", "name": "White" }
			]
		},
		"spacing": {
			"units": [ "px", "rem", "%", "vw", "vh" ]
		},
		"typography": {
			"fontFamilies": [
				{
					"fontFamily": "-apple-system, BlinkMacSystemFont, \"Segoe UI\", sans-serif",
					"name": "System Sans",
					"slug": "system-sans"
				}
			]
		}
	},
	"styles": {
		"color": {
			"background": "#ffffff",
			"text": "#0f172a"
		},
		"typography": {
			"fontFamily": "var(--wp--preset--font-family--system-sans)",
			"lineHeight": "1.6"
		}
	}
}
